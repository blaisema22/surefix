# SureFix Backend Environment Variables
# Copy this to .env and fill in your values

# ========================================
# DATABASE (MySQL)
# ========================================
DB_HOST=localhost
DB_USER=root
DB_PASS=your_mysql_password
DB_NAME=surefix

# ========================================
# TWILIO SMS (Required for real phone SMS)
# ========================================
# 1. Sign up: https://www.twilio.com/try-twilio
# 2. Get free trial phone/SMS service
# 3. Dashboard → Account Info → SID / Auth Token
# 4. Messaging → Services → Create Messaging Service → Get SID
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# JWT (Auto-generated if missing)
# ========================================
JWT_SECRET=your-super-secret-jwt-key-here-change-this

# ========================================
# Other (optional)
# ========================================
PORT=5000
NODE_ENV=development


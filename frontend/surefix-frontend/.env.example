# Copy to .env and add your values
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here
VITE_APP_NAME=SureFix

# Get API key from:
# 1. https://console.cloud.google.com/apis/library/maps-javascript-api
# 2. Create credentials -> API Key
# 3. Enable Maps JavaScript API
# 4. Optional: Restrict to your frontend domain
